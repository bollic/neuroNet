 <!-- views/indexZoneGeo.ejs -->
<%- include('layout/headerZoneGeo') %>
 <script>
  window.APP_VIEW = "<%= mode %>";
</script>

<style>
  html, body { height: 100%; }
#map {

  width: 100%;
  height: calc(100vh - 120px);
}
  .leaflet-container {
  z-index: 0 !important;
}
#drawer-toggle-btn {
  position: fixed;
  bottom: 6rem; /* circa 96px */
  left: 1rem;
  z-index: 3000;
}
</style>

<style>
  .fab {
  position: absolute;
  bottom: 20px;
  right: 20px;
  width: 50px;
  height: 50px;
  border-radius: 50%;
  font-size: 24px;
  background: #2c7be5;
  color: white;
  border: none;
  cursor: pointer;
}

.map-wrapper {
  position: relative;
  height: 100%;
}

#form-panel {
  max-height: calc(100vh - 140px);
  bottom: 50px;
  overflow-y: auto;

  padding-bottom: calc(120px + env(safe-area-inset-bottom));

  border-top-left-radius: 16px;
  border-top-right-radius: 16px;
}
@media (min-width: 768px) {
  #form-panel {
    bottom: 30px;
    max-height: calc(100vh - 120px);
  }
}

.hidden {
  display: none;
}


.close-btn {
  position: absolute;
  top: 10px;
  right: 15px;
  background: none;
  border: none;
  font-size: 18px;
  cursor: pointer;
}
</style>
<style>
/* Forza la visualizzazione delle emoji nei marker personalizzati */
.leaflet-div-icon {
  background: none !important;
  border: none !important;
}
.leaflet-div-icon div {
  font-family: "Apple Color Emoji", "Segoe UI Emoji", "Noto Color Emoji", sans-serif;
  text-align: center;
}
</style>

<style>
  #group-feed {
    max-height: none !important;   /* niente limite altezza */
    overflow-y: visible !important; /* elimina scrollbar verticale */
  }
</style>
<style>
  .floating-btn {
  bottom: calc(7rem + env(safe-area-inset-bottom));
}
footer {
  padding-bottom: env(safe-area-inset-bottom);
}
</style>

<style>
    #map-section {
      min-height: 0;
  }
    footer {
      width: 100%;
    }
</style>

   <!-- 1: inizio flex -->
<div class="flex flex-row ">
<!-- 2: drawer -->
  
      <!-- Contenuto principale (mappa) -->
  <div class="drawer-content relative flex-1">
    <!-- Pulsante toggle sempre visibile -->
      <% if (mode === "field") { %> 
