         <% } %>
          <!-- 3:  unica mappa -->
    <div id="content-sections" class="relative w-full">
      <!-- 🗺️ MAPPA -->
  <div id="map-section" class="relative flex-1">
  <div id="map" class="w-full h-full"></div>

      <div class="absolute top-4 right-4 z-[2000]">
      <button id="profile-btn"
