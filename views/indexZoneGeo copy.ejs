          <% } %>
        </div>


</div>

  
</div>
    <% if (mode === "field") { %> 
        <div id="form-panel"
            class="hidden fixed bottom-20 left-1/2 -translate-x-1/2 
            w-[95%] sm:w-[90%] max-w-md 
            bg-white shadow-xl z-[2000] p-4 rounded-2xl">   
            <button id="close-form-btn">✕</button>

                <h3 id="form-title">Nouveau Signalement</h3>

          <%- include('partials/addPointForm.ejs') %>
        </div>
     

        <!-- 🔴 Pulsante Add Point centrato sopra il footer -->
        <button
          id="open-add-point"
          class="fixed bottom-28 left-1/2 -translate-x-1/2
           z-10 bg-white border border-gray-300 rounded-full p-3 shadow-lg hover:scale-110 transition-transform">
          <i class="fas fa-plus text-gray-700 text-xl"></i>
        </button>
         <% } %>
      </div>
    <!-- 🕸️ Pulsante toggle drawer (resta sopra tutto) -->

    <!-- 📍 Pulsante geolocalizzazione -->
    <button id="use-my-location"
            class="fixed bottom-28 right-4 z-[3000] bg-white border border-gray-300 rounded-full p-3 shadow-lg hover:scale-110 transition-transform">
      <i class="fas fa-crosshairs text-gray-700 text-xl"></i>
    </button>

    <!-- 👥 Toggle punti gruppo -->
     <% if (mode === "field") { %>
    <div class="fixed bottom-40 right-4 z-[3000] flex items-center gap-2 text-xs bg-white/90 backdrop-blur px-3 py-2 rounded-full shadow-lg">
      <span>👥 Groupe</span>
      <input type="checkbox" id="toggleGroupPoints" 
      class="toggle toggle-primary toggle-sm"
       />
    </div>
    <% } %>
          <!-- 👤 PROFILO (inizialmente nascosto) -->
      <%# include('partials/profileSection', { user: user, referenteOffice: referenteOffice }) %>
    </div>
      </div>   
        <!-- Sidebar- a sinistra -->
    <!-- Fine .container-fluid -->
    <!-- ✨ Toast di benvenuto dinamico solo per utenti 'field' -->
    <!-- ✨ Fine toast -->
    <!-- 💫 FLASH MESSAGE SESSIONE (onboarding field) -->
    <script>
      window.points = <%- JSON.stringify(points || []) %>;
    <% if (mode === "field") { %>
  window.currentUserId = "<%= user._id %>";
    window.planUX = <%- JSON.stringify(planUX) %>;
     console.log("🧪 PLAN UX:", window.planUX);
<% } %>
      window.CATEGORIES = <%- JSON.stringify(categories || []) %>;
      console.log("🧪 categorie dell'utente field:", window.CATEGORIES);
      console.log("🧪 categorie dell'utente field:", <%- JSON.stringify(categories || []) %>);
      console.log("🔎 Points lato client:", <%- JSON.stringify(points || []) %>);
      
    </script>

</div> <!-- 🔒 chiusura flex-row -->
<!-- ✅ MODAL EDIT (DaisyUI) -->
<input type="checkbox" id="edit-modal" class="modal-toggle" />
    <% if (mode === "field") { %> 
      <div class="modal">
        <div class="modal-box">
          <h3 class="font-bold text-lg">Modifier</h3>

          <input id="edit-name" class="input input-bordered w-full" />

          <textarea id="edit-description" class="textarea w-full mt-2"></textarea>

          <div class="modal-action">
            <button onclick="saveEdit()" class="btn btn-primary">Save</button>
            <label for="edit-modal" class="btn">Cancel</label>
          </div>
        </div>
      </div>
    <% } %>
<%- include('layout/footer') %>

<script>
  const openProfileBtn = document.getElementById('open-profile');
  const goPlanBtn = document.getElementById('go-plan');
  const mapSection = document.getElementById('map-section');
  const profileSection = document.getElementById('profile-section');
 const btn = document.getElementById("profile-btn");
const panel = document.getElementById("profile-panel");

btn?.addEventListener("click", (e) => {
  e.stopPropagation();
  panel.classList.toggle("hidden");
});

// chiudi cliccando fuori
document.addEventListener("click", () => {
  panel?.classList.add("hidden");
});
  function openProfile() {
    mapSection.classList.add('hidden');
    profileSection.classList.remove('hidden');
  }

  function closeProfile() {
    profileSection.classList.add('hidden');
    mapSection.classList.remove('hidden');
    if (window.map && typeof window.map.invalidateSize === 'function') {
      setTimeout(() => window.map.invalidateSize(), 300);
    }
  }

  if (openProfileBtn) openProfileBtn.addEventListener('click', openProfile);
  if (goPlanBtn) goPlanBtn.addEventListener('click', closeProfile);

  // ESC per chiudere il profilo
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeProfile();
  });
</script>
<script>
document
  .getElementById("menu-btn")
  ?.addEventListener("click", () => {

    document
      .getElementById("menu-panel")
      ?.classList.toggle("hidden");

  });
</script>

<script>

document
  .getElementById("start-first-point")
  ?.addEventListener("click", () => {
    // apre il pannello
    document
      .getElementById("form-panel")
      ?.classList.remove("hidden");

        // 🔥 ATTIVA selezione punto
    window.isSelectingPoint = true;

    // feedback UX
    document.body.style.cursor = "crosshair";

    alert("Cliquez sur la carte pour ajouter le point");
});

</script>
