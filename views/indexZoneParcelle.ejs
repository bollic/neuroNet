<!--indexZoneParcelle.ejs-->

<%- include('layout/headerZoneParcelle') %>

<style>
  html, body { height: 100%; }
   #map {   
     height: 70%;
    width: 100%; 
    position: relative;   /* 👈 AGGIUNGI QUESTO */
    z-index: 10;          /* 👈 AGGIUNGI QUESTO */
     
  }

  .leaflet-container {
  z-index: 0 !important;
  }
</style>
<style>
.drawer-side {
    pointer-events: none;
    z-index: 1 !important;   /* 👈 BASSO */
}

.drawer-side aside {
    pointer-events: auto;
    z-index: 2;
}
</style>
  <style>
.highlight-row {
  background-color: #ffe9a8 !important;
}
</style>

<style>
  #group-feed {
    max-height: none !important;   /* niente limite altezza */
    overflow-y: visible !important; /* elimina scrollbar verticale */
  }
</style>

   <!-- 1: inizio flex -->

<!-- 2: drawer -->

    <!-- CONTENUTO -->
      <!-- ✅ OBBLIGATORIO -->
   <div class="drawer-content h-full px-6 py-4"> 
      <% if (showWelcomeAddPoint) { %>
    <div class="flex items-start gap-4">
      <div class="flex-shrink-0">
        <label for="my-drawer" class="btn btn-primary btn-sm shadow">
          ☰ Menu
        </label>
      </div>

      <div class="flex-1">
        <%- include('partials/onboardingAddAction', {
          description: "Vous pouvez maintenant dessiner votre première parcelle.",
          actionUrl: "/addParcelle",
          actionLabel: "Ajouter"
        }) %>
      </div>
    </div>
  <% } else { %>

    <div>
      <label for="my-drawer" class="btn btn-primary btn-sm shadow">
        ☰ Menu
      </label>
    </div>

  <% } %>
    <div class="flex h-full gap-4">



   <!-- MENU SOPRA -->

      <aside class="w-80 bg-base-200 p-4 overflow-y-auto">
        
        <!-- Tabella parcelles -->    
  <% if (parcelles && parcelles.length > 0) { %>
    <div class="overflow-x-auto">
     <!-- AGGIUNGI id="main-table" QUI -->
   <table id="main-table" class="table table-zebra w-full"> 
     <thead class="table-dark">
         <tr>
            <th>Numero</th>
            <th>Name</th>           
             <th>Action</th>
          </tr>
        </thead>
        <tbody>
<% parcelles.forEach((parcelle, index) => { %>
  <% const coordinates = parcelle.geometry.coordinates[0] || []; %>
  <% coordinates.forEach((coord, i) => { %>
    <tr class="parcelle-item" data-id="<%= parcelle._id %>" data-vertex="<%= i %>">
      <td><%= i + 1 %></td>
      <td><%= parcelle.name %></td>     
      <td> 
      <a href="/delete-point/<%= parcelle._id %>?lat=<%= coord[1] %>&lng=<%= coord[0] %>" class="btn btn-sm btn-outline-danger">
         <i class="fas fa-trash"></i>
       </a>
      </td>
    </tr>
  <% }) %>
<% }) %>

        </tbody>
      </table>
    </div>
  <% } else { %>
    <div class="text-center text-secondary mt-5">
              Aucune parcelle trouvée pour vous ! Ajoutez votre première parcelle 🌱
            </div>
  <% } %>
      
  
      </aside>
  <!-- MAPPA -->
     <div class="flex-1 relative">
    <div id="map" class="w-full h-full rounded-lg shadow-md"></div>
 
     <% if (!showWelcomeAddPoint) { %>
      <a href="/addParcelle"
         class="absolute bottom-14 right-8 z-50">
        <button class="btn btn-warning btn-sm shadow-lg rounded-full px-4">
          ➕ Ajouter
        </button>
      </a>
    <% } %>
    
     </div>
   </div> <!-- 👈 CHIUDE drawer-content -->
       
</div>

        <!-- Sidebar- a sinistra -->
  
     <label for="my-drawer" class="drawer-overlay lg:hidden" style="display:none;"></label>    
 

</div> <!-- fine flex -->


</div>  <!-- 👈 QUESTA è la chiusura del drawer -->

<!-- script sotto -->

 <!-- chiusura container -->

<script>

  // Variabile JS usata dal client
  const parcelles = <%- JSON.stringify(parcelles || []) %>;
  console.log("📦 Parcelles dal server:", <%- JSON.stringify(parcelles) %>);
  window.CATEGORIES = <%- JSON.stringify(categories || []) %>;     
   console.log("🧪 CATEGORIES DAL SERVER:", window.CATEGORIES);
</script>

<script type="module" src="/js/dataAuthorParcelle.js" defer></script>
<%- include('layout/footer') %>
