<!--indexZoneParcelle.ejs-->

<%- include('layout/headerZoneParcelle') %>

<style>
  html, body { height: 100%; }

   #map {   
     height: 100%;
    width: 100%; 
    position: relative;   /* 👈 AGGIUNGI QUESTO */
    z-index: 10;          /* 👈 AGGIUNGI QUESTO */
     
  }

  .leaflet-container {
  z-index: 1 !important;
  }
</style>
<style>
  /*
.drawer-side {
    pointer-events: none;
    z-index: 1 !important;
}

.drawer-side aside {
    pointer-events: auto;
    z-index: 2;
}
*/
</style>
  <style>
.highlight-row {
  background-color: #ffe9a8 !important;
}
</style>

<style>
  #group-feed {
    max-height: none !important;   /* niente limite altezza */
    overflow-y: visible !important; /* elimina scrollbar verticale */
  }
</style>
<div class="drawer">

  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <!-- CONTENUTO PRINCIPALE -->
  <div class="drawer-content h-screen flex flex-col">

    <!-- TOP BAR MOBILE -->
    <div class="p-2 md:hidden">
      <label for="my-drawer" class="btn btn-primary btn-sm shadow">
        ☰ Menu
      </label>
    </div>

    <!-- AREA PRINCIPALE -->
    <div class="flex flex-1 min-h-0 md:gap-4">
            <!-- SIDEBAR DESKTOP -->
      <aside class="hidden md:block w-80 bg-base-200 p-4 overflow-y-auto">

        <% if (parcelles && parcelles.length > 0) { %>
          <table class="table table-zebra w-full">
            <tbody>
              <% parcelles.forEach((parcelle, index) => { %>
                <tr class="parcelle-item" data-id="<%= parcelle._id %>">
                  <td><%= index + 1 %></td>
                  <td><%= parcelle.name %></td>
                  <td>
                    <a href="/delete-parcelle/<%= parcelle._id %>"
                       class="btn btn-xs btn-outline-danger">
                      🗑
                    </a>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <div class="text-center text-secondary mt-5">
            Aucune parcelle trouvée 🌱
          </div>
        <% } %>

      </aside>

      <!-- MAPPA -->
      <div class="flex-1 relative min-h-0">

        <!-- 🔥 FIX IMPORTANTE: wrapper con altezza garantita -->
        <div class="absolute inset-0">

          <div id="map" class="w-full h-full z-0"></div>

        </div>
      
      </div>


    </div>
  </div>

  <!-- SIDEBAR MOBILE -->
  <div class="drawer-side md:hidden">
    <label for="my-drawer" class="drawer-overlay"></label>

    <aside class="w-80 bg-base-200 p-4 overflow-y-auto">

      <% if (parcelles && parcelles.length > 0) { %>
        <table class="table table-zebra w-full">
          <tbody>
            <% parcelles.forEach((parcelle, index) => { %>
              <tr class="parcelle-item" data-id="<%= parcelle._id %>">
                <td><%= index + 1 %></td>
                <td><%= parcelle.name %></td>
                <td>
                  <a href="/delete-parcelle/<%= parcelle._id %>"
                     class="btn btn-xs btn-outline-danger">
                    🗑
                  </a>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } else { %>
        <div class="text-center text-secondary mt-5">
          Aucune parcelle trouvée 🌱
        </div>
      <% } %>

    </aside>
  </div>

</div>

     <!-- 🔥 BOTTONE ADD SEMPRE VISIBILE -->

<!-- 🔥 GLOBAL FLOATING BUTTON (FORZA SOPRA TUTTO) -->
<div style="
  position: fixed;
  bottom: 64px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 2147483647;
  pointer-events: auto;
">
  <a href="/addParcelle">
    <button style="
      background: #facc15;
      color: black;
      padding: 12px 20px;
      border-radius: 9999px;
      font-weight: 600;
      box-shadow: 0 10px 25px rgba(0,0,0,0.3);
      border: none;
    ">

      <span>➕</span>
      <span>Ajouter</span>

    </button>
  </a>

</div>

<script>

  // Variabile JS usata dal client
  const parcelles = <%- JSON.stringify(parcelles || []) %>;
  console.log("📦 Parcelles dal server:", <%- JSON.stringify(parcelles) %>);
  window.CATEGORIES = <%- JSON.stringify(categories || []) %>;     
   console.log("🧪 CATEGORIES DAL SERVER:", window.CATEGORIES);
</script>

<script type="module" src="/js/dataAuthorParcelle.js" defer></script>
<%- include('layout/footer') %>
