<!-- views/partials/sidebarProfile.ejs -->
<details class="bg-base-100 rounded-lg shadow-sm mb-3 text-sm">

  <!-- HEADER CLICCABILE -->
  <summary class="px-3 py-2 cursor-pointer flex items-center justify-between font-semibold">
    <div class="flex items-center gap-2">
      <i class="fas fa-user text-primary text-sm"></i>
      <span>Profil</span>
    </div>
    <span class="text-xs opacity-60 truncate max-w-[120px]">
      <%= user.email %>
    </span>
  </summary>

  <!-- CONTENUTO -->
  <div class="px-3 pb-3">

    <!-- XP inline -->
    <div class="flex justify-between items-center text-xs mb-2">
      <div class="flex gap-2">
        <span class="badge badge-primary badge-sm">
          Signalements <%= pointsXp || 0 %>
        </span>
        <span class="badge badge-secondary badge-sm">
          Zones <%= parcelleXp || 0 %>
        </span>
      </div>
      <span class="badge badge-outline badge-sm">
        Total <%= PointsUsed || 0 %>
      </span>
    </div>

    <!-- Progress mini -->
    <progress
      class="progress progress-primary w-full h-2"
      value="<%= planUX.used %>"
      max="<%= planUX.limit %>">
    </progress>
    <div class="text-[10px] opacity-60 mt-1">
      Plan <%= plan.toUpperCase() %>
    </div>
    <% if (referenteOffice) { %>
  <div class="text-[11px] opacity-70 mt-2">
    Responsable: <%= referenteOffice.email %>
      </div>
    <% } %>

    <div class="text-[10px] text-right opacity-60 mt-1">
      <%= planUX.used %> / <%= planUX.limit %>
    </div>

    <!-- Badges mini -->
    <% if (user.badges && user.badges.length > 0) { %>
      <div class="flex flex-wrap gap-1 mt-2">
        <% user.badges.forEach(b => { %>
          <span class="badge badge-accent badge-xs">
            <%= b.name || b.code %>
          </span>
        <% }) %>
      </div>
    <% } %>
      <hr class="my-3">

<div class="flex flex-col gap-2 text-xs">
  <a href="/logout" 
    class="btn btn-outline btn-sm w-full">
    🚪 Se déconnecter
  </a>

  <form action="/delete_account" method="POST"
        onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer votre compte ? Cette action est irréversible.')">
    <button type="submit"
      class="btn btn-error btn-sm w-full">
      🗑 Supprimer mon compte
    </button>
  </form>

</div>
  </div>

</details>

