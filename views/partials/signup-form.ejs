<!-- partials/signup-form.ejs -->
<% if (role === "field") { %>
    <!-- Messaggio di errore -->
<% if (typeof error !== 'undefined' && error) { %>

    <div class="bg-red-100 text-red-800 p-2 rounded mb-4">
      ⚠️ <%= error %>
    </div>
  <% } %>

  <!-- 🧭 Membre / Déclarant : form d'inscription dans un groupe existant -->
  
<form id="signup-form" action="/signup" method="POST" class="space-y-4">


<p class="text-sm text-gray-600 mb-2">
En tant que <strong>membre (Déclarant)</strong>, vous rejoignez le groupe :
</p>

<p class="font-semibold text-lg">
🏘️ <%= groupName %>
</p>

<p class="text-xs text-gray-500 mb-3">
Vous pourrez ajouter des signalements sur la carte.
</p>
<input type="hidden" name="group" value="<%= group %>">
  

    <!-- Email -->
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700">
        Email
      </label>
      <input
        type="email"
        name="email"
        id="email"
        required
        class="input input-bordered w-full mt-1"
      />
    </div>

    <!-- Password -->
    <div>
      <label for="password" class="block text-sm font-medium text-gray-700">
        Mot de passe
      </label>
      <input
        type="password"
        name="password"
        id="password"
        required
        class="input input-bordered w-full mt-1"
      />
    </div>

    <!-- Rôle caché -->
    <input type="hidden" name="role" value="field">

    <!-- Bouton -->
    <button type="submit" class="btn btn-primary w-full mt-2">
     🚀 Rejoindre et signaler
    </button>
  </form>
<% } else if (role === "office") { %>
  <!-- 🏢 Responsable : form de création de groupe -->
  <form id="signup-form" action="/signup" method="POST" class="space-y-4">

    <p class="text-sm text-gray-600 mb-2">
      En tant qu’<strong>Responsable</strong>, vous <u>créez</u> un nouveau groupe
      et en devenez le référent principal.
    </p>

    <!-- Nom du groupe -->
    <div>
      <label for="group" class="block text-sm font-medium text-gray-700">
        Nom du groupe / communauté
      </label>
      <input type="text" id="group" name="groupName"
        placeholder="Ex. 9369 ou TOUC"
        required
        class="input input-bordered w-full mt-1" />
    </div>

    <!-- Email -->
    <div>
      <label for="email" class="block text-sm font-medium text-gray-700">
        Email
      </label>
      <input type="email" name="email" id="email" required
        class="input input-bordered w-full mt-1" />
    </div>

    <!-- Password -->
    <div>
      <label for="password" class="block text-sm font-medium text-gray-700">
        Password
      </label>
      <input type="password" name="password" id="password" required
        class="input input-bordered w-full mt-1" />
    </div>

    <!-- Rôle caché -->
    <input type="hidden" name="role" value="office">

    <!-- Bouton -->
    <button type="submit" class="btn btn-primary w-full mt-2">
      🏢 Créer mon groupe
    </button>
  </form>
<% } else { %>
  <!-- 🛠️ Autres rôles (admin ou inconnu) -->
  <p class="text-sm text-gray-500">Aucune inscription disponible pour ce rôle.</p>
<% } %>



