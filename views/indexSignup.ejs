<%- include('layout/header') %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.0.0-beta2/js/bootstrap.bundle.min.js" integrity="sha512-43iShtbiyImxjjU4a9rhXBy7eKtIsrpll8xKhe1ghKqh5NyfME8phZs5JRFZpRBe1si44WM3tNmnqMym7JRmDQ==" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<style>
#main-table {
  table-layout: fixed; /* forza larghezza colonne */
  width: 100%;
}
/* Celle e intestazioni */
#main-table th, 
#main-table td {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  text-align: center;
  vertical-align: middle;
  font-size: 0.85rem;
  padding: 6px;
}
</style>
<style>
  #main-table td:last-child,
#main-table th:last-child {
  width: 90px;
}
</style>
<div class="container mx-auto px-4">
   <h1 class="mt-4 mb-3">UTILISATEURS</h1>
   <button class="navbar-toggler"  data-bs-target="#my-nav"  data-bs-toggle="collapse" aria-controls="my-nav"  aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button> 

  <div class="row my-2">
    <div class="col-lg-12">     
      <div class="table-responsive">
        <% if (user) { %> <!-- Vérifie si l'utilisateur connecté est défini -->
          <h2>Bienvenue, <%= user.email %>!</h2>
          <a href="/logout">Se déconnecter</a>
        <% } else { %>
          <a href="/login">Se connecter</a>
          <a href="/signup">S'inscrire</a>
        <% } %>
        <% if (groupedUsers && Object.keys(groupedUsers).length > 0) { %>
         <table id="main-table" class="table table-striped table-sm text-center mb-2">
            <thead>
              <tr>
                <th>INDEX</th>  
                  
                <th>E-Mail</th>
                <th>Group</th>
                 <th>Action Office </th>   
                <th>Action Field</th>
              </tr>
            </thead>
            <tbody>
              <% Object.entries(groupedUsers).forEach(([groupId, group]) => { %>

                <!-- HEADER GROUPE -->
               <tr class="bg-gray-50 border-t">
                  <td colspan="5" class="py-3">
                    <strong class="text-blue-600">
                      👥 <%= group.groupName %>
                    </strong>
                  </td>
                </tr>

                <!-- OFFICE -->
                <% if (group.office) { %>
                  <tr class="bg-blue-50">
                    <td class="font-semibold text-blue-600">OFFICE</td>
                  
                    <td><%= group.office.email %></td>
                    <td><%= group.office.groupId %></td>
                    <td>
                      <a href="/edit/<%= group.office._id %>" class="text-success">
                        <i class="fas fa-edit fa-lg mx-1"></i>
                      </a>

                      <a href="/del/<%= group.office._id %>"
                        class="text-danger"
                        onclick="return confirm('Supprimer ?');">
                        <i class="fas fa-trash fa-lg mx-1"></i>
                      </a>
                    </td>
                  </tr>
                <% } %>

              <!-- FIELDS -->
              <% group.fields.forEach(field => { %>

                <tr class="hover:bg-gray-50 transition">
                  <td>FIELD</td>
                 
                  <td><%= field.email %></td>
                  <td><span class="badge bg-light text-dark">
                        <%= field.groupId %>
                      </span>
                  </td>

                  <td>
                  </td>

                  <td>
                    <a href="/edit/<%= field._id %>" class="text-success">
                      <i class="fas fa-edit fa-lg mx-1"></i>
                    </a>

                    <a href="/del/<%= field._id %>"
                      class="text-danger"
                      onclick="return confirm('Supprimer ?');">
                      <i class="fas fa-trash fa-lg mx-1"></i>
                    </a>
                  </td>
                </tr>

              <% }) %>

    <% }) %>
            </tbody>
          </table>
        <% } else { %>
          <h1 class="text-center text-secondary mt-5">
            Aucun utilisateur trouvé dans la base de données !
          </h1>
        <% } %>
      </div>     
    </div>
  </div>
</div>

<%- include('layout/footer') %>
