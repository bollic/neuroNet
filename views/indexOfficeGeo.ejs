<!-- indexofficeGeo.ejs-->

<%- include('layout/headerOfficeGeo') %>

<% if (justCreatedGroup) { %>
  <div class="toast toast-top toast-end z-50">
    <div class="alert alert-success shadow-lg">
      <div>
        <span>🎉 Groupe créé avec succès !</span>
      </div>
    </div>
  </div>

  <script>
    setTimeout(() => {
      const toast = document.querySelector('.toast');
      if (toast) toast.remove();
    }, 4000);
  </script>
<% } %>

<style>
  html, body { height: 100%; }
  #map { height: 48vh }

  .leaflet-container { z-index: 0 !important; }
</style>

<div class="drawer lg:drawer-open h-[calc(100vh-64px)]">
  <input id="my-drawer" type="checkbox" class="drawer-toggle" />

  <!-- CONTENUTO PRINCIPALE -->
  <div class="drawer-content flex flex-col relative  p-4">

    <a class="absolute top-4 left-4 z-50">
      <label for="my-drawer" class="btn btn-primary btn-sm shadow-lg">☰ Menu</label>
    </a>
    <!-- 🔗 Invitation privée (compacte) -->
<div class="mt-2 p-2 bg-base-100 rounded-lg border border-dashed text-sm">

  <div class="flex items-center justify-between mb-1">
    <h4 class="font-semibold text-sm">
      🔗 Inviter des déclarants
    </h4>

    <span class="text-xs text-warning">
      🔒 Lien privé
    </span>
  </div>
   <% if (justCreatedGroup) { %>
    <div class="mb-2 p-2 bg-success/10 border border-success rounded text-success text-xs">
      🎉 Votre groupe est prêt !  
      Envoyez ce lien aux membres pour commencer à recevoir des signalements.
    </div>
  <% } %>
  <% if (!categories || categories.length <= 2) { %>
        <div class="alert alert-warning mt-4">
          <span>
            ⚠️ Aucune catégorie définie.<br>
            Les déclarants ne pourront pas classer les signalements.<br>
            💡 Conseil : créez des catégories avant d'inviter des déclarants.
          </span>
        </div>
      <% } %>
  <div class="flex items-center gap-2">
    <input
      type="text"
      readonly
      class="input input-bordered input-xs w-full"
      value="<%= baseUrl %>/join/<%= group.groupId %>"
    />

    <button
      class="btn btn-xs btn-outline"
      onclick="
        navigator.clipboard.writeText(this.previousElementSibling.value);
        this.innerText = '✔';
        setTimeout(() => this.innerText = 'Copier', 1200);
      ">
      Copier
    </button>
  </div>

</div>

<!-- 🏷️ CONTEXTE DU GROUPE -->
<div class="mt-8 mb-4 p-4 bg-base-100 rounded-xl shadow-sm">

<div class="flex items-center gap-3 flex-wrap">
  <h1 class="text-xl font-semibold text-gray-800">
    🏷️ <%= group?.name || "Groupe" %>
  </h1>

  <% if (group?.isPublic) { %>
    <span class="badge badge-success badge-sm">
      🌍 Groupe public
    </span>
  <% } else { %>
    <span class="badge badge-warning badge-sm">
      🔒 Groupe privé
    </span>
  <% } %>
</div>


  <% if (group?.description) { %>
    <p class="text-sm text-gray-600 mt-1 italic">
      <%= group.description %>
    </p>
  <% } else { %>
    <p class="text-xs text-gray-400 mt-1">
      Aucune description définie. 
      <a href="/groups/<%= group.groupId %>" class="underline text-primary">
        Ajouter une description
      </a>
    </p>
  <% } %>

  <% if (group?.keywords && group.keywords.length > 0) { %>
    <div class="mt-2 flex flex-wrap gap-2">
      <% group.keywords.forEach(k => { %>
        <span class="badge badge-outline badge-sm">
          <%= k %>
        </span>
      <% }) %>
    </div>
  <% } %>
</div>

 

    <!-- MAPPA -->
    <div id="map" class="w-full rounded-lg "></div>

  </div>

  <div class="drawer-side" style="width: 440px; flex: 0 0 440px;">
  <label for="my-drawer" class="drawer-overlay"></label>

    <aside class="w-full bg-base-200 p-4 overflow-y-auto pb-20">

    <!-- 🔧 Gestione info gruppo -->
      <div class="mb-4">
       <a href="/groups/<%= group.groupId %>"
          class="btn btn-outline btn-primary w-full">
          ✏️ Modifier les informations du groupe
        </a>
      </div>
      <!-- Filtro -->
      <div class="flex space-x-4 my-3">
        <select id="filter-category" class="select select-bordered">
         <option value="">Toutes les catégories</option>

        </select>
        <input type="date" id="filter-date" class="input input-bordered" />
      </div>
      
      <!-- Stato piano -->
       
<div class="my-3 p-3 bg-base-100 rounded-lg shadow-md">
  <h3 class="font-bold text-lg mb-1">Votre plan</h3>

    <span class="badge <%= plan === 'free' ? 'badge-warning' : plan === 'pro' ? 'badge-success' : 'badge-primary' %>">
      <%= plan.toUpperCase() %>
    </span>
    <p class="text-sm mt-1">
      👥 Déclarants : <strong><%= fieldUX.used %></strong> / <%= fieldUX.limit %>
    </p>
     <% if (fieldUsers && fieldUsers.length > 0) { %>
    <p class="text-sm mt-1 font-semibold">Déclarants du groupe :</p>
    <ul class="ml-4 list-disc text-sm">
      <% fieldUsers.forEach(f => { %>
        <li><%= f.email %></li>
      <% }) %>
    </ul>
  <% } %>
    <% if (fieldUX.blocked) { %>
      <p class="text-xs text-warning">
        Limite de déclarants atteinte
      </p>
    <% } %>

<p class="text-sm mt-1">
  Limite : <%= maxPoints === Infinity ? 'illimité 🚀' : maxPoints + ' signalements' %>
</p>


<% if (group.planExpiresAt) { %>
  <p class="text-xs text-warning">
    Essai Pro jusqu’au <%= new Date(group.planExpiresAt).toLocaleString() %>
  </p>
<% } %>

<% if (plan === 'free') { %>
  <form action="/pay/pro" method="POST" class="mt-3">
    <button type="submit" class="btn btn-success w-full">
     🚀 Activer le plan Pro

    </button>
  </form>
  <p class="text-xs text-gray-500 mt-1 text-center">
  Essai Pro • aucun paiement • activation immédiate
</p>
<% } else { %>
  <p class="mt-3 text-sm text-success font-medium">
    ✅ Plan Pro actif – limites étendus
  </p>
<% } %>
</div>

<!-- Tabella punti (stile lista card) -->
<div class="mt-4 card bg-base-100 shadow-md">
  <div class="card-body">
    <h5 class="text-lg font-bold mb-2">Signalements par déclarant</h5>
    <details class="mb-4">
  <summary class="cursor-pointer font-semibold">
  🔐 Partage de la description
  </summary>
    <% pointsByField.forEach(f => { %>
  <div class="mb-4 p-3 border rounded">
    <h6 class="font-semibold">
      <%= f.email %> (<%= f.points.length %> signalements)
    </h6>

    <% f.points.forEach(p => { %>
      <div class="flex items-center gap-2 ml-4 mt-2">
        <span>📍 <%= p.name %></span>

        <select
          class="select select-bordered select-sm"
          onchange="shareDescription('<%= p._id %>', this.value)">
         <option value="">Partager avec…</option>

          <% fieldUsers.forEach(u => { 
               if (u._id.toString() !== f.userId) { %>
            <option value="<%= u._id %>">
              <%= u.email %>
            </option>
          <% } }) %>
        </select>
      </div>
    <% }) %>
  </div>
<% }) %>
  
</details>
    <div class="overflow-x-auto">
      <table id="main-table" class="table table-zebra w-full">
        <thead>
          <tr>
            <th>Signalement</th>
            <th>Catégorie</th>
            <th>Date</th>
            <th style="display:none;">createdAtISO</th>
          </tr>
        </thead>
        <tbody></tbody>
      </table>
    </div>
  </div>
</div>

      <!-- Form categorie globali -->
      <div class="mt-4 card bg-base-100 shadow-md w-full max-w-full overflow-hidden">
        <div class="card-body w-full overflow-hidden">
          <h5 class="text-lg font-bold mb-2">Catégories de signalement</h5>
          <p class="text-sm text-gray-500">
            Choisissez des catégories simples et actionnables.
          </p>
          <p><strong><%= categories.map(c => c.name).join(', ') %></strong></p>

          <form id="categories-form" action="/update-categories" method="POST" class="flex flex-col gap-2">
             <div class="flex flex-wrap gap-2 mt-2">
            <div id="category-list" class="flex flex-col gap-2 w-full">
             
            </div>
              <button type="button" id="add-category" class="btn btn-secondary btn-sm w-full">
    ➕ Ajouter une catégorie
  </button>

  <button type="submit" class="btn btn-primary w-full">
    💾 Enregistrer les catégories
  </button>
           </div>
          </form>
        </div>
      </div>

    </aside>
  </div>
</div>
<script>
async function shareDescription(pointId, fieldId) {
  if (!fieldId) return;

  await fetch(`/office/points/${pointId}/visibility`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    credentials: 'include',
    body: JSON.stringify({ fieldId })
  });

  alert('Description condivisa');
}
</script>

<script>
  window.FIELD_USERS = <%- JSON.stringify(fieldUsers || []) %>;
  window.POINTS = <%- JSON.stringify(points || []) %>;
  window.CATEGORIES = <%- JSON.stringify(categories || []) %>;
</script>

<%- include('layout/footerOffice') %>
<script src="/js/dataOfficeGeo.js" defer></script>
