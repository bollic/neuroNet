<%- include('layout/header') %>

<div class="min-h-screen flex flex-col items-center justify-center text-center px-6 pb-32">

  <!-- Hero -->
  <h1 class="text-5xl sm:text-6xl font-extrabold text-purple-700 mb-4">
    Terria
  </h1>

  <p class="text-xl text-gray-700 max-w-2xl mb-2">
    Cartographiez, partagez et organisez des signalements.
  </p>

  <p class="text-sm text-gray-500 max-w-xl mb-10">
   Un outil collaboratif pour centraliser et partager des signalements.

  </p>

  <!-- Actions principales -->
  <div class="flex flex-col sm:flex-row gap-4 mb-6">

    <a href="/login?role=field"
       class="btn btn-primary btn-lg rounded-full px-8 shadow-lg">
      👤 Je fais des signalements
    </a>

    <a href="/login?role=office"
       class="btn btn-outline btn-lg rounded-full px-8">
      🏢 Je gère un groupe
    </a>

  </div>

  <!-- Action secondaire -->
  <a href="/groups"
     class="text-sm text-purple-600 hover:underline">
    Rejoindre un groupe existant
  </a>

  <!-- Micro-explication (discrète) -->
  <p class="text-xs text-gray-400 max-w-md mt-8">
    Les responsables créent les groupes et définissent les catégories.  
    Les déclarants ajoutent des signalements sur la carte.
  </p>

</div>

<%- include('layout/footerIndexCopy') %>
